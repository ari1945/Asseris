# W10 deploy — template variabel untuk docker-compose.yml (server + Postgres).
# SALIN ke `.env` di folder yang sama, lalu isi nilainya. `.env` di-IGNORE git (lihat .gitignore);
# `.env.example` ini AMAN di-commit (tanpa rahasia nyata).
#
#   cp .env.example .env        # lalu edit
#   docker compose up --build   # compose otomatis memuat .env di sebelahnya
#
# Generate APP_ENCRYPTION_KEY (32-byte hex):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# --- WAJIB ---
# Password Postgres (dipakai db service + DATABASE_URL server). Untuk validasi lokal bebas;
# untuk prod pakai rahasia kuat.
POSTGRES_PASSWORD=changeme

# Kunci enkripsi totpSecret-at-rest (AES-256-GCM). 32-byte hex/base64. Kosong = TOTP tak terenkripsi.
APP_ENCRYPTION_KEY=

# --- OPSIONAL ---
# Set 1 HANYA bila server berada di belakang TLS (cookie auth jadi Secure). Lokal/HTTP: biarkan 0.
COOKIE_SECURE=0

# CSV IP/CIDR yang boleh login (allowlist admin). Kosong = nonaktif.
ADMIN_IP_ALLOWLIST=

# Proxy narasi LLM (W8). Kosong = fitur "Jelaskan temuan" graceful-off.
LLM_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

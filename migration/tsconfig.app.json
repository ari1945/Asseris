{
  "//": "NeoSuite AMS — W11 APP tier (lapisan data .ts, lalu view .tsx). RELAKS & di-ratchet: strict OFF awalnya, dikencangkan per slice. Kanon tetap FULL strict di tsconfig.json (terpisah). include = daftar eksplisit file app yang sudah dikonversi (tumbuh per slice) agar ledakan error terkendali. Lihat 'PRD - W11' & BUILD.md.",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",

    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": []
  },
  "include": [
    "src/app-globals.d.ts",
    "src/data_facilities.ts",
    "src/data_proforma.ts",
    "src/data_licensing.ts",
    "src/data_firmops.ts",
    "src/data_fpm.ts",
    "src/data_isak35.ts",
    "src/data_knowledge.ts",
    "src/data_legaldigital.ts",
    "src/data_ojk.ts",
    "src/data_people.ts",
    "src/data_platform.ts",
    "src/data_pph23.ts",
    "src/data_psak117.ts",
    "src/data_records.ts",
    "src/data_reg_compliance.ts",
    "src/data_risk.ts",
    "src/data_sakroadmap.ts",
    "src/data_syariah.ts",
    "src/data_templates.ts",
    "src/data_travel.ts",
    "src/data_part3.ts",
    "src/data_part4.ts",
    "src/data_import.ts",
    "src/data_part1.ts",
    "src/data_procurement.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

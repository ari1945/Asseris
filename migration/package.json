{
  "name": "neosuite-ams",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NeoSuite AMS — CANONICAL app (Vite + ESM). src/ is hand-maintained source (W3). Buildless app/ + NeoSuite AMS.html at repo root are a FROZEN reference only.",
  "scripts": {
    "_codemod_RETIRED": "node codemod.mjs — DO NOT RUN: src/ is canonical now; this would overwrite hand edits. Kept for reference only.",
    "dev": "vite",
    "dev:all": "concurrently -k -n server,vite -c blue,green \"npm --prefix ../server run dev\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@trpc/client": "^11.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}

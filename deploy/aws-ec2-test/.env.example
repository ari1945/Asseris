# === AWS EC2 test deploy — environment ===
# Copy to ".env" beside this file and fill in. NEVER commit the real .env.
#   cp deploy/aws-ec2-test/.env.example deploy/aws-ec2-test/.env

# --- Database ---
POSTGRES_PASSWORD=change-me-to-something-strong

# --- App secrets (BOTH required in prod/NODE_ENV=production — server fail-fast refuses boot otherwise) ---
# Leave these two EMPTY if using SECRETS_PROVIDER=aws-sm below (fetched from Secrets Manager instead).
#
# 32-byte key, hex. Encrypts the TOTP secret at rest.
# Generate:  openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Ed25519 private key (base64 PKCS8 DER). Signs export seals; stable value = seals verify across restarts.
# Generate:  openssl genpkey -algorithm ed25519 -outform DER | base64 -w0
APP_SIGNING_KEY=

# --- Secrets manager (opt-in, server/src/secrets.ts) — real client data on this host is a real ---
# --- risk if it's ever compromised; move APP_ENCRYPTION_KEY/APP_SIGNING_KEY/etc out of the .env ---
# --- file and into AWS Secrets Manager once you have real AWS access. Leave SECRETS_PROVIDER ---
# --- empty for the default .env-file path (nothing below matters then). ---
# aws-sm = fetch one JSON secret {"APP_ENCRYPTION_KEY":"...","APP_SIGNING_KEY":"...",...} from AWS
# Secrets Manager at boot, merged into env (an explicit var above still wins if you set both).
# Auth = the container's default AWS credential chain (EC2 instance profile) — NOT access keys;
# IAM policy needed: secretsmanager:GetSecretValue on the one secret ARN below.
SECRETS_PROVIDER=
AWS_SECRETS_MANAGER_SECRET_ID=
AWS_REGION=

# --- Backup (M6) — SEPARATE key from APP_ENCRYPTION_KEY (separation of duties) ---
# Encrypts the daily pg_dump (AES-256). LOSING THIS = backups unrecoverable → store it apart from the DB.
# Generate:  openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# --- Public hostname (Caddy serves + gets TLS for this) ---
# No domain yet? Use sslip.io with your EC2 public IP, dots replaced by dashes:
#   IP 13.54.2.9  ->  PUBLIC_HOST=13-54-2-9.sslip.io
# NOTE: if the instance stops/starts the public IP changes — attach an Elastic IP,
#       or update PUBLIC_HOST to the new IP each time.
PUBLIC_HOST=

# --- TLS mode ---
# internal (DEFAULT, self-signed) = works instantly, no domain/DNS/port-80 needed; browser shows a
#   cert warning once. Fine for a closed pilot.
# acme = real Let's Encrypt cert. REQUIRES a real DNS A-record for PUBLIC_HOST + port 80/443
#   reachable from the public internet. This is the bar for external clients — don't train users
#   to click through "connection not private" warnings.
CADDY_TLS_MODE=internal

# 1 = Secure cookies (we terminate TLS at Caddy). Keep 1.
COOKIE_SECURE=1

# Leave EMPTY for this test. Behind a reverse proxy the login allowlist would see
# Caddy's IP via the socket, not your real IP (X-Forwarded-For), and lock you out.
ADMIN_IP_ALLOWLIST=

# --- Optional: LLM narration proxy (leave blank to disable) ---
LLM_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

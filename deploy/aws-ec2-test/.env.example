# === AWS EC2 test deploy — environment ===
# Copy to ".env" beside this file and fill in. NEVER commit the real .env.
#   cp deploy/aws-ec2-test/.env.example deploy/aws-ec2-test/.env

# --- Database ---
POSTGRES_PASSWORD=change-me-to-something-strong

# --- App secrets (BOTH required in prod/NODE_ENV=production — server fail-fast refuses boot otherwise) ---
# 32-byte key, hex. Encrypts the TOTP secret at rest.
# Generate:  openssl rand -hex 32
APP_ENCRYPTION_KEY=

# Ed25519 private key (base64 PKCS8 DER). Signs export seals; stable value = seals verify across restarts.
# Generate:  openssl genpkey -algorithm ed25519 -outform DER | base64 -w0
APP_SIGNING_KEY=

# --- Backup (M6) — SEPARATE key from APP_ENCRYPTION_KEY (separation of duties) ---
# Encrypts the daily pg_dump (AES-256). LOSING THIS = backups unrecoverable → store it apart from the DB.
# Generate:  openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# --- Public hostname (Caddy serves + gets TLS for this) ---
# No domain yet? Use sslip.io with your EC2 public IP, dots replaced by dashes:
#   IP 13.54.2.9  ->  PUBLIC_HOST=13-54-2-9.sslip.io
# NOTE: if the instance stops/starts the public IP changes — attach an Elastic IP,
#       or update PUBLIC_HOST to the new IP each time.
PUBLIC_HOST=

# 1 = Secure cookies (we terminate TLS at Caddy). Keep 1.
COOKIE_SECURE=1

# Leave EMPTY for this test. Behind a reverse proxy the login allowlist would see
# Caddy's IP via the socket, not your real IP (X-Forwarded-For), and lock you out.
ADMIN_IP_ALLOWLIST=

# --- Optional: LLM narration proxy (leave blank to disable) ---
LLM_API_KEY=
LLM_PROVIDER=
LLM_MODEL=

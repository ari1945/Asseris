# Copy to "terraform.tfvars" beside this file and fill in. NEVER commit the real terraform.tfvars
# (or terraform.tfstate — both are gitignored).
#   cp deploy/aws-ec2-test/terraform/terraform.tfvars.example deploy/aws-ec2-test/terraform/terraform.tfvars

firm_name = "acme-kap"          # short slug, lowercase/digits/dash — becomes the Name tag

aws_region     = "ap-southeast-3"  # Jakarta (README default); ap-southeast-1 (Singapore) alternative
instance_type  = "t3.small"        # or t4g.small (ARM, cheaper — all images used here are multi-arch)

key_name = "your-ec2-keypair-name" # must already exist in this AWS account/region (Console > EC2 > Key Pairs)

# YOUR IP ONLY. Never 0.0.0.0/0 — the security group rejects that value with a validation error.
# Find it: curl -s https://checkip.amazonaws.com
allowed_ssh_cidr = "203.0.113.4/32"

use_elastic_ip = true # keeps PUBLIC_HOST stable across stop/start (README recommendation)

# extra_tags = { ClientId = "ACME-001" }

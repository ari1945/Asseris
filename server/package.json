{
  "name": "neosuite-ams-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "NeoSuite AMS — W6 backend (tRPC + Prisma/SQLite). Server-side SSOT for engagement state; localStorage demotes to offline cache. Dev = SQLite; prod (W10) flips datasource to Postgres.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "seed": "tsx src/seed.ts",
    "bootstrap": "tsx src/bootstrap.ts",
    "add-user": "tsx src/addUserCli.ts",
    "rotate-encryption-key": "tsx src/rotateEncryptionKey.ts",
    "export-audit-log": "tsx src/exportAuditLog.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --skip-generate && tsx src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1078.0",
    "@prisma/client": "^6.2.1",
    "@trpc/server": "^11.0.0",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

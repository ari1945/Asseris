// NeoSuite AMS — W6 data model (Fase 0).
// Core entities (firm/user/client/engagement/WTB) seeded from migration/src/data.js,
// + StateDoc: the versioned key/value store that replaces the ams.*/ams.v1.* localStorage
// keys as the cross-browser SSOT. Numbers are Float (JS double — exact for the < 2^53
// integers used here, so zero numeric drift vs the in-app constants).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Dev: SQLite (zero-ops, single file). Prod (W10): change to "postgresql" — no
  // vendor-specific SQL is used, so the flip is a one-line datasource change.
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Firm {
  id          String       @id
  name        String
  short       String
  license     String?
  partners    Int          @default(0)
  managers    Int          @default(0)
  staff       Int          @default(0)
  users       User[]
  team        TeamMember[]
  clients     Client[]
  engagements Engagement[]
  roles       Role[]
}

// RBAC admin console — dynamic replacement for the hardcoded GRANTS map in
// migration/src/rbac.ts. `capsJson` is a JSON string array of CAP keys (e.g. '["wp.edit","llm.use"]'),
// validated against the fixed CAP catalog at the API boundary (server/src/router.ts roles.*), not by
// a DB constraint. `isBuiltIn` marks the 6 roles ported from the old static GRANTS at seed/bootstrap
// time — their NAME and existence are locked (no rename/delete), but capsJson remains editable like
// any custom role (PRD docs/prd-rbac-admin-console.md §8.3/§11 Q2). `User.role` stays a free-text
// string (not a FK here) matching Role.name — see rbac-admin-console PRD §9 for why a full FK
// migration across 73 existing call sites was deliberately avoided.
model Role {
  id        String   @id @default(cuid())
  firmId    String
  firm      Firm     @relation(fields: [firmId], references: [id])
  name      String
  capsJson  String   @default("[]")
  isBuiltIn Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([firmId, name])
}

model User {
  id       String  @id
  firmId   String
  firm     Firm    @relation(fields: [firmId], references: [id])
  name     String
  initials String?
  role     String
  email    String? @unique // login identity (W7). SQLite treats multiple NULLs as distinct.
  dataJson String // full original USER object (lossless envelope for the ~15 profile fields)

  // W7 — authentication credentials. All optional so the W6 seed stays valid until
  // the seed sets them; scrypt hash (Node built-in crypto, no native dep). TOTP secret
  // is base32; totpEnabled flips true only after a verify. failedLogins/lockedUntil drive
  // brute-force lockout.
  passwordHash String?
  totpSecret   String?
  totpEnabled  Boolean   @default(false)
  failedLogins Int       @default(0)
  lockedUntil  DateTime?

  sessions            Session[]
  authEvents          AuthEvent[]
  engagementMemberships EngagementMember[]
}

// W7.5 — per-engagement data isolation. A user may read/write an engagement's WORKING DATA
// (bootstrap + StateDoc scope='engagement' + WTB) only if they are a member here, OR their role
// has the ENGAGEMENT_VIEW_ALL capability (Partner/Manager oversight). The free-text
// Engagement.partner/manager name fields are NOT a membership source (they don't map to login users).
model EngagementMember {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  addedAt      DateTime   @default(now())

  @@unique([engagementId, userId])
  @@index([userId])
}

// W7 — opaque server-side session. Token is random (≥128-bit); resolved on every
// request to populate ctx.user. Absolute expiry (expiresAt) + sliding lastSeenAt;
// logout sets revokedAt. Transport (cookie vs header) is the client's concern (Fase 2).
model Session {
  id         String    @id @default(cuid())
  token      String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?
  userAgent  String?
  ip         String?

  @@index([userId])
}

// W7 — append-only authentication audit trail (real LOGIN/LOGOUT/MFA/password events,
// not seed). userId is nullable so failed logins on unknown emails are still recorded.
model AuthEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  kind      String // LOGIN | LOGIN_FAIL | LOGOUT | PASSWORD_CHANGE | TOTP_ENROLL | TOTP_VERIFY | LOCKOUT
  ts        DateTime @default(now())
  ip        String?
  userAgent String?
  detail    String?

  @@index([userId])
  @@index([ts])
}

// W8 — append-only LLM proxy usage audit (who called the proxy, when, which provider/model).
// Records usage, NOT content — the prompt and the model output (which carry redacted finding
// text) are never persisted. kind = NARRATE | ERROR | RATE_LIMIT | FORBIDDEN | NOT_CONFIGURED.
model LlmEvent {
  id       String   @id @default(cuid())
  userId   String?
  kind     String
  ts       DateTime @default(now())
  provider String?
  model    String?
  detail   String? // e.g. "findings=5; in=1200 out=300" — no client data

  @@index([userId])
  @@index([ts])
}

// W10 — append-only, hash-chained audit trail. Replaces the client-side pseudo-hash demo
// (window.amsFakeHash / buildAuditStream in view_crypto/view_records) with a server-owned,
// tamper-evident record. Each row chains to the previous via hash =
// SHA-256(seq|ts|actor|action|target|detail|prevHash); the first row chains to GENESIS_HASH.
// There is NO update/delete endpoint — appends only (appendAudit), reads (audit.list), and
// integrity re-computation (audit.verify) — so a client can neither rewrite nor reorder history.
// `seq` is assigned server-side under an in-process serialization queue (single-process Node);
// horizontal scaling would need DB-level sequencing (see deploy notes). `detail` carries ONLY
// metadata (key + version delta), never working-paper content — so the trail is safe to read
// across roles without leaking another engagement's numbers.
model AuditLog {
  id          String   @id @default(cuid())
  seq         Int      @unique // monotonic chain position, assigned by appendAudit
  ts          DateTime // explicit (NOT @default) — the exact value hashed into the chain
  actorUserId String?
  actorRole   String?
  action      String // STATE_SET | LOGIN | LOGOUT | LLM_NARRATE
  scope       String? // engagement | firm | user (for STATE_SET)
  scopeId     String?
  key         String?
  detail      String? // metadata only, e.g. "v3->v4" — never working-paper content
  prevHash    String
  hash        String

  @@index([ts])
  @@index([actorUserId])
}

// W10.5 — nol-vendor cryptographic seal over an export artifact. NOT a legal e-Meterai / PSrE
// signature — it proves provenance (which authenticated user) + integrity (the content hash was
// not altered), nothing about Indonesian stamp-duty law. `contentHash` is the client-computed
// SHA-256 of the artifact's CANONICAL content payload (not the raw PDF/XLSX bytes — those vary
// per render); `signature` is an Ed25519 signature over that hash by the server signing key
// (env APP_SIGNING_KEY, or an ephemeral dev key). verifySeal looks a row up by id and re-checks
// both the hash equality and the signature, so a verifier need not trust the embedded copy.
model Seal {
  id           String   @id @default(cuid()) // public sealId, embedded in the artifact
  kind         String // opinion | fs | materiality | register:<name> | …
  contentHash  String // SHA-256 hex of the canonical content payload
  scope        String? // engagement | firm | user
  scopeId      String?
  signerUserId String
  signerRole   String?
  signedAt     DateTime @default(now())
  pubKeyId     String // identifies the signing key (sha256 of the public key, truncated)
  signature    String // base64 Ed25519 signature over contentHash

  @@index([scope, scopeId])
  @@index([signerUserId])
}

// K4 hardening — archive of every Ed25519 PUBLIC key that has ever been the active
// APP_SIGNING_KEY. Auto-recorded by createSeal() (via ensureSigningKeyArchived) before
// every seal is signed, so a key rotation can never "forget" to archive: by the time a
// new key is live, the old key's public half is already durable here. verifySeal looks
// a seal's key up BY pubKeyId (not "is this today's key"), so seals remain verifiable
// forever across any number of rotations, as long as this row survives (it's covered by
// the normal DB backup — no separate secret-management concern since only the PUBLIC
// half is stored).
model SigningKey {
  pubKeyId  String   @id
  publicKey String // base64 SPKI DER — sufficient to verify, never the private half
  createdAt DateTime @default(now())
}

model TeamMember {
  id     String @id @default(cuid())
  firmId String
  firm   Firm   @relation(fields: [firmId], references: [id])
  name   String
  role   String
  util   Int    @default(0)
}

// W9 — external data connector definition (SSOT). Seeded byte-faithfully from the client
// blueprint window.IMPORT.CONNECTORS (migration/src/data_import.js), which was the prototype's
// simulated source. W9 makes the server the source of truth: a connector here is the contract
// (identity, target SSOT module, OAuth scopes, field mapping) that a provider adapter fulfils.
// `wired` flips true once a real adapter (fixture or HTTP) drives it end-to-end; non-wired
// connectors stay in the simulated/available state the prototype showed (offline fallback in the
// read-model). Display-only fields (icon/uptime/latency/vol/expiry/webhooks/syncs/desc) ride in
// metaJson — a lossless envelope, mirroring User.dataJson — so the read-model can reconstruct the
// exact prototype card without bloating queryable columns.
model Connector {
  id          String  @id // 'coretax' | 'bank' | 'esign' | 'dms' | …
  name        String
  category    String // 'Perpajakan' | 'Keuangan' | 'Dokumen' | …
  target      String // owner module id the data is POSTED into (the SSOT) — e.g. 'cashbank'
  status      String // connected | available | error  (baseline/seed status)
  auth        String? // 'OAuth 2.0 · mTLS' | 'API Key + HMAC' | …  (human label)
  endpoint    String?
  schedule    String?
  scopesJson  String  @default("[]") // string[]  — OAuth scopes
  mappingJson String  @default("[]") // [[sourceLabel, targetField], …]  — field map
  metaJson    String  @default("{}") // lossless display envelope (icon/uptime/latency/vol/expiry/webhooks/syncs/desc/last)
  wired       Boolean @default(false) // true once a real adapter drives this connector (Fase 1+)

  jobs   SyncJob[]
  tokens ConnectorToken[]
}

// W9 — one sync run. The job runner (Fase 1) appends a row per pull: pull → stage → validate →
// control-total gate → idempotent post to the target SSOT → here. `rows/valid/rejected/posted`
// make the import↔consumption tie-out checkable; `gatePassed` records whether the control total
// matched the owner's figure (posting is blocked when it didn't). `cursor` carries the
// idempotency / incremental-pull marker so a re-run posts zero duplicates.
model SyncJob {
  id           String    @id @default(cuid())
  connectorId  String
  connector    Connector @relation(fields: [connectorId], references: [id])
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String // running | posted | staged | failed
  mode         String    @default("auto") // auto | semi
  dataset      String?
  target       String? // target module id (mirror of Connector.target at run time)
  unit         String?
  rows         Int       @default(0)
  valid        Int       @default(0)
  rejected     Int       @default(0)
  posted       Int       @default(0)
  controlLabel String?
  controlValue String?
  gatePassed   Boolean   @default(false)
  note         String?
  cursor       String? // idempotency / incremental-pull marker

  @@index([connectorId])
  @@index([startedAt])
}

// W9 — a connector's stored credentials, encrypted at rest (crypto/secretbox, AES-256-GCM, the
// same key as the TOTP secret). secretEnc holds encryptSecret(JSON.stringify({...tokens})); it is
// NEVER returned to the client. With no APP_ENCRYPTION_KEY the box is a dev pass-through (still
// never sent to the browser). The OAuth login/refresh flow is out of W9 Fase 1 scope — tokens are
// provisioned via seed/env for the fixture adapter; the real-HTTP adapter consumes the same row.
model ConnectorToken {
  id          String    @id @default(cuid())
  connectorId String    @unique
  connector   Connector @relation(fields: [connectorId], references: [id])
  kind        String    @default("oauth") // oauth | apikey | service
  secretEnc   String // encrypted JSON token bundle — never leaves the server
  expiresAt   DateTime?
  updatedAt   DateTime  @updatedAt
}

model Client {
  id          String       @id
  firmId      String
  firm        Firm         @relation(fields: [firmId], references: [id])
  name        String
  industry    String?
  tier        String?
  risk        String?
  npwp        String?
  city        String?
  listed      Boolean      @default(false)
  since       Int?
  partner     String?
  fee         Float?
  status      String?
  engagements Engagement[]
}

model Engagement {
  id          String   @id
  firmId      String
  firm        Firm     @relation(fields: [firmId], references: [id])
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  type        String?
  fy          String?
  standard    String?
  status      String?
  phase       String?
  progress    Int      @default(0)
  partner     String?
  manager     String?
  deadline    String?
  budgetHrs   Int?
  actualHrs   Int?
  risk        String?
  materiality Float?
  // K7 — set by engagement.archive (FIRM_ADMIN-only). Null = not yet archived. Drives the SA 230
  // ¶A21 assembly-lock in state.set (ASSEMBLY_LOCK_DAYS after this timestamp, further engagement-
  // scoped writes require CAP.PHASE_OVERRIDE) and the retention display in view_records.tsx.
  archivedAt  DateTime?
  wtb         WtbRow[]
  members     EngagementMember[]
}

// Working Trial Balance rows for an engagement. Mirrors the runtime object shape
// window.AMS.WTB carries: { key, group, code, name, ly, unadj, aje, adj, lead } where
// adj = unadj + aje (derived, recomputed on hydration — not stored). `key` is 'wtb'+ord,
// also derivable from `ord`. Seeded in Fase 0; becomes the boot-hydration source that
// frees canon from reading window.AMS.WTB at module-load (Fase 3).
model WtbRow {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  ord          Int
  group        String
  code         String
  name         String
  ly           Float      @default(0)
  unadj        Float      @default(0)
  aje          Float      @default(0)
  lead         String?

  @@index([engagementId])
}

// The versioned SSOT for all mutable app state. One row per (scope, scopeId, key):
//   scope='engagement' scopeId=ENG-…  key='aje' | 'wpState' | 'diagnostics.v1' | …
//   scope='firm'       scopeId=FIRM-…  key='clients' | 'engagements'
//   scope='user'       scopeId=USER-…  key='profile' | 'role' | prefs
// `version` drives optimistic concurrency: writes pass a baseVersion and the server
// does an atomic compare-and-swap (UPDATE … WHERE version = baseVersion).
model StateDoc {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  key       String
  valueJson String
  version   Int      @default(1)
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@unique([scope, scopeId, key])
  @@index([scope, scopeId])
}

// K7 — immutable, append-only history of every StateDoc write. StateDoc itself only ever holds
// the CURRENT value (that's the whole point of the CAS design); this table answers SA 230's
// "what did the working paper say before it changed, and who changed it, when" — a gap the
// versioned-but-current-only StateDoc could not close on its own. Populated inside the SAME
// transaction as the StateDoc write (server/src/router.ts state.set), so it can never drift from
// what StateDoc actually holds. One row per version EVER written (no unique-per-document
// constraint like StateDoc — this is the append log, not the SSOT).
model StateDocHistory {
  id        String   @id @default(cuid())
  scope     String
  scopeId   String
  key       String
  version   Int
  valueJson String
  updatedAt DateTime @default(now())
  updatedBy String?

  @@unique([scope, scopeId, key, version])
  @@index([scope, scopeId, key])
}
